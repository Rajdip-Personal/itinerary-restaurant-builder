{
  "model": "global.anthropic.claude-opus-4-6-v1",
  "permissions": {
    "allow": [
      "Task(*)",
      "Glob(*)",
      "Grep(*)",
      "Edit(*)",
      "Write(*)",
      "Read(*)",
      "Bash(*)",
      "mcp__jira-mcp__*",
      "mcp__confluence-mcp__*",
      "mcp__github__*",
      "mcp__nordstrom-slack__*",
      "mcp__nordstrom-schema-repo__*",
      "mcp__aha-mcp__*",
      "mcp__servicenow__*",
      "mcp__mawm-data__*"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write(memory-bank/*)",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[$(date '+%Y-%m-%d %H:%M:%S')] Memory bank updated: $CLAUDE_TOOL_INPUT_FILE_PATH\" >> memory-bank/.update-log"
          }
        ]
      },
      {
        "matcher": "Write(docs/outputs/user-stories.md)",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[$(date '+%Y-%m-%d %H:%M:%S')] User stories updated\" >> memory-bank/.update-log"
          }
        ]
      },
      {
        "matcher": "Write(docs/outputs/requirements.md)",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[$(date '+%Y-%m-%d %H:%M:%S')] Requirements updated\" >> memory-bank/.update-log"
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "AWS_PROFILE": "claude_code"
  }
}
